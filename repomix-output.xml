<file path="components/Header.tsx">
"use client";

import React, { useState, useRef, useEffect } from "react";
import Link from "next/link";
import { usePathname, useRouter } from "next/navigation";
import { useApp } from "@/context/AppContext";
import { ShoppingCart, User, LogOut, ChevronDown, Sparkles } from "lucide-react";
import Image from "next/image";
import { ModeToggle } from "@/components/ModeToggle";

export default function Header() {
  const { user, cart, logout } = useApp();
  const [dropdownOpen, setDropdownOpen] = useState(false);
  const dropdownRef = useRef<HTMLDivElement>(null);
  const pathname = usePathname();
  const router = useRouter();

  // Close dropdown when clicking outside
  useEffect(() => {
    function handleClickOutside(event: MouseEvent) {
      if (dropdownRef.current && !dropdownRef.current.contains(event.target as Node)) {
        setDropdownOpen(false);
      }
    }
    document.addEventListener("mousedown", handleClickOutside);
    return () => {
      document.removeEventListener("mousedown", handleClickOutside);
    };
  }, []);

  // Close dropdown on route change
  useEffect(() => {
    const timer = setTimeout(() => {
      setDropdownOpen(false);
    }, 0);
    return () => clearTimeout(timer);
  }, [pathname]);

  const handleLogout = () => {
    logout();
    router.push("/");
  };

  return (
    <header id="app-header" className="sticky top-0 z-40 w-full border-b border-slate-100 bg-white/80 backdrop-blur-md dark:border-zinc-800 dark:bg-zinc-950/80">
      <div className="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        {/* Left Side: Logo & Main Nav */}
        <div className="flex items-center gap-6">
          <Link id="logo-link" href="/" className="flex items-center gap-2 group">
            <div className="flex h-9 w-9 items-center justify-center rounded-xl bg-slate-900 text-white transition-transform group-hover:scale-105 dark:bg-zinc-100 dark:text-zinc-900">
              <Sparkles className="h-5 w-5 text-indigo-400 dark:text-indigo-600" />
            </div>
            <span className="font-sans font-bold text-lg tracking-tight text-slate-900 dark:text-zinc-50">
              Prompt <span className="text-indigo-600 dark:text-indigo-400">Market</span>
            </span>
          </Link>

          <Link
            id="header-nav-prompts"
            href="/prompts"
            className={`text-xs sm:text-sm font-bold px-3 py-1.5 rounded-xl transition-all ${
              pathname === "/prompts"
                ? "text-indigo-600 bg-indigo-50 dark:text-indigo-400 dark:bg-indigo-950"
                : "text-slate-600 hover:text-indigo-600 hover:bg-slate-50 dark:text-zinc-400 dark:hover:text-indigo-400 dark:hover:bg-zinc-800"
            }`}
          >
            프롬프트
          </Link>
        </div>

        {/* Right Side: Navigation & User Menu */}
        <nav id="header-nav" className="flex items-center gap-3">
          {/* Theme Toggle */}
          <ModeToggle />

          {user ? (
            <div className="flex items-center gap-3">
              {/* Cart Button */}
              <Link
                id="cart-icon-link"
                href="/cart"
                className="relative p-2 text-slate-600 hover:text-indigo-600 hover:bg-slate-50 rounded-xl transition-all dark:text-zinc-400 dark:hover:text-indigo-400 dark:hover:bg-zinc-800"
                aria-label="장바구니 이동"
              >
                <ShoppingCart className="h-5 w-5" />
                {cart.length > 0 && (
                  <span
                    id="cart-badge"
                    className="absolute -top-1 -right-1 flex h-5 min-w-5 items-center justify-center rounded-full bg-indigo-600 px-1 text-[10px] font-bold text-white shadow-sm font-mono border-2 border-white animate-pulse dark:border-zinc-950"
                  >
                    {cart.length}
                  </span>
                )}
              </Link>

              {/* User Dropdown */}
              <div className="relative" ref={dropdownRef}>
                <button
                  id="user-dropdown-btn"
                  onClick={() => setDropdownOpen(!dropdownOpen)}
                  className="flex items-center gap-2 rounded-xl p-1.5 pr-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-all border border-slate-100 dark:text-zinc-300 dark:hover:bg-zinc-800 dark:border-zinc-700"
                >
                  <div className="relative h-7 w-7 overflow-hidden rounded-full border border-slate-200 dark:border-zinc-600">
                    <Image
                      src={user.profileImage || "https://picsum.photos/seed/user-avatar/150/150"}
                      alt="프로필 이미지"
                      fill
                      sizes="28px"
                      className="object-cover"
                      referrerPolicy="no-referrer"
                    />
                  </div>
                  <span className="hidden sm:inline-block max-w-[100px] truncate">{user.nickname}</span>
                  <ChevronDown className={`h-4 w-4 text-slate-400 transition-transform dark:text-zinc-500 ${dropdownOpen ? "rotate-180" : ""}`} />
                </button>

                {/* Dropdown Menu */}
                {dropdownOpen && (
                  <div
                    id="user-dropdown-menu"
                    className="absolute right-0 mt-2 w-48 origin-top-right rounded-2xl border border-slate-100 bg-white p-2 shadow-xl ring-1 ring-black/5 focus:outline-none animate-in fade-in slide-in-from-top-2 duration-150 dark:border-zinc-700 dark:bg-zinc-900 dark:ring-white/5"
                  >
                    <div className="px-3 py-2 border-b border-slate-50 mb-1 dark:border-zinc-800">
                      <p className="text-[11px] font-mono text-slate-400 dark:text-zinc-500">CONNECT AS</p>
                      <p className="text-xs font-semibold text-slate-800 truncate dark:text-zinc-200">{user.email}</p>
                    </div>

                    <Link
                      id="menu-profile-link"
                      href="/profile"
                      className="flex w-full items-center gap-2 rounded-xl px-3 py-2 text-left text-sm text-slate-700 hover:bg-slate-50 hover:text-indigo-600 transition-all dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-indigo-400"
                    >
                      <User className="h-4 w-4 text-slate-400 dark:text-zinc-500" />
                      <span>프로필 관리</span>
                    </Link>

                    <Link
                      id="menu-mypage-link"
                      href="/my-page"
                      className="flex w-full items-center gap-2 rounded-xl px-3 py-2 text-left text-sm text-slate-700 hover:bg-slate-50 hover:text-indigo-600 transition-all dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-indigo-400"
                    >
                      <ShoppingCart className="h-4 w-4 text-slate-400 dark:text-zinc-500" />
                      <span>구매 내역</span>
                    </Link>

                    <hr className="my-1 border-slate-50 dark:border-zinc-800" />

                    <button
                      id="menu-logout-btn"
                      onClick={handleLogout}
                      className="flex w-full items-center gap-2 rounded-xl px-3 py-2 text-left text-sm text-rose-600 hover:bg-rose-50 hover:text-rose-700 transition-all font-medium dark:text-rose-400 dark:hover:bg-rose-950 dark:hover:text-rose-300"
                    >
                      <LogOut className="h-4 w-4 text-rose-400 dark:text-rose-500" />
                      <span>로그아웃</span>
                    </button>
                  </div>
                )}
              </div>
            </div>
          ) : (
            <Link
              id="login-header-btn"
              href="/login"
              className="rounded-xl bg-slate-900 px-4 py-2 text-xs sm:text-sm font-semibold text-white shadow-sm hover:bg-slate-800 transition-all dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-white"
            >
              로그인
            </Link>
          )}
        </nav>
      </div>
    </header>
  );
}
</file>

