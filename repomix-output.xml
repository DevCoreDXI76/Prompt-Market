"use client";

import React, { useState, useEffect } from "react";
import { useParams, useRouter } from "next/navigation";
import { useApp } from "@/context/AppContext";
import { PROMPT_PRODUCTS, PromptProduct } from "@/lib/promptData";
import { ShoppingCart, Copy, Check, ArrowLeft, Star, Clock, Sparkles, ShieldCheck, CreditCard } from "lucide-react";
import Link from "next/link";
import Image from "next/image";

export default function PromptDetailPage() {
  const { id } = useParams();
  const router = useRouter();
  const { addToCart, isInCart, isPurchased, addPurchases, addToast, user } = useApp();

  const product = id ? (PROMPT_PRODUCTS.find((p) => p.id === id) || null) : null;
  const [activeImageIdx, setActiveImageIdx] = useState(0);
  const [copied, setCopied] = useState(false);
  const [showCheckoutModal, setShowCheckoutModal] = useState(false);

  if (!product) {
    return (
      <div className="flex min-h-[calc(100vh-4rem)] items-center justify-center p-4">
        <div className="text-center">
          <p className="text-slate-500">프롬프트를 찾는 중입니다...</p>
          <Link href="/" className="mt-4 inline-block text-sm text-indigo-600 hover:underline">
            메인 페이지로 돌아가기
          </Link>
        </div>
      </div>
    );
  }

  const purchased = isPurchased(product.id);
  const inCart = isInCart(product.id);

  const handleCopy = async () => {
    try {
      await navigator.clipboard.writeText(product.prompt_text);
      setCopied(true);
      addToast("프롬프트가 클립보드에 복사되었습니다!");
      setTimeout(() => setCopied(false), 2000);
    } catch (err) {
      addToast("복사에 실패했습니다. 직접 복사해 주세요.");
    }
  };

  const handleDirectBuy = () => {
    if (!user) {
      router.push("/login");
      return;
    }
    setShowCheckoutModal(true);
  };

  const confirmDirectCheckout = () => {
    addPurchases([product.id]);
    setShowCheckoutModal(false);
    addToast("결제가 완료되었습니다!");
  };

  const getCategoryBadgeColor = (category: string) => {
    switch (category) {
      case "ChatGPT":
        return "bg-emerald-50 text-emerald-700 border-emerald-100";
      case "Midjourney":
        return "bg-indigo-50 text-indigo-700 border-indigo-100";
      case "Stable Diffusion":
        return "bg-purple-50 text-purple-700 border-purple-100";
      case "Claude":
        return "bg-orange-50 text-orange-700 border-orange-100";
      default:
        return "bg-slate-50 text-slate-700 border-slate-100";
    }
  };

  return (
    <div id="prompt-detail-container" className="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      {/* Back Button */}
      <Link
        id="back-to-home"
        href="/"
        className="inline-flex items-center gap-1.5 text-xs sm:text-sm font-semibold text-slate-500 hover:text-slate-900 mb-6 transition-colors"
      >
        <ArrowLeft className="h-4 w-4" />
        <span>돌아가기</span>
      </Link>

      <div className="grid grid-cols-1 gap-10 lg:grid-cols-12 items-start">
        {/* Left Column: Image Gallery & Detailed Info */}
        <div className="lg:col-span-7 space-y-8">
          {/* Image Gallery Area */}
          <div className="space-y-3">
            <div className="relative aspect-[4/3] w-full overflow-hidden rounded-2xl bg-slate-100 border border-slate-100 shadow-sm">
              <Image
                src={product.images[activeImageIdx]}
                alt={`${product.title} 결과물`}
                fill
                sizes="(max-width: 1024px) 100vw, 58vw"
                className="object-cover transition-all duration-300"
                referrerPolicy="no-referrer"
              />
            </div>
            {/* Gallery Thumbnails */}
            {product.images.length > 1 && (
              <div className="flex gap-2.5 overflow-x-auto pb-2">
                {product.images.map((img, idx) => (
                  <button
                    key={idx}
                    id={`thumb-${idx}`}
                    onClick={() => setActiveImageIdx(idx)}
                    className={`relative aspect-[4/3] w-20 overflow-hidden rounded-lg border-2 bg-slate-50 transition-all ${
                      activeImageIdx === idx ? "border-indigo-600 ring-2 ring-indigo-500/10" : "border-transparent hover:border-slate-300"
                    }`}
                  >
                    <Image
                      src={img}
                      alt="섬네일"
                      fill
                      sizes="80px"
                      className="object-cover"
                      referrerPolicy="no-referrer"
                    />
                  </button>
                ))}
              </div>
            )}
          </div>

          {/* Description Area */}
          <div className="rounded-2xl border border-slate-100 bg-white p-6 sm:p-8 shadow-sm">
            <h2 className="font-display font-bold text-lg sm:text-xl text-slate-900 border-b border-slate-50 pb-4 mb-4">
              프롬프트 상세 정보
            </h2>
            <div className="prose prose-slate max-w-none text-slate-600 text-xs sm:text-sm leading-relaxed whitespace-pre-line">
              {product.description}
            </div>
          </div>
        </div>

        {/* Right Column: Checkout Action Card (Sticky) */}
        <div className="lg:col-span-5 lg:sticky lg:top-24">
          <div className="rounded-2xl border border-slate-100 bg-white p-6 shadow-md space-y-6">
            {/* Title & Tags */}
            <div className="space-y-3">
              <div className="flex items-center gap-2">
                <span className={`rounded-lg px-2.5 py-1 text-[10px] font-bold border ${getCategoryBadgeColor(product.category)}`}>
                  {product.category}
                </span>
                <span className="text-[11px] text-slate-400 font-medium">제작자: {product.author}</span>
              </div>
              <h1 className="font-sans font-bold text-xl sm:text-2xl text-slate-900 leading-snug tracking-tight">
                {product.title}
              </h1>
              <div className="flex items-center gap-1 text-sm font-semibold text-amber-500 font-sans">
                <Star className="fill-current h-4 w-4" />
                <span>{product.rating}</span>
                <span className="text-slate-200 font-normal">|</span>
                <span className="text-slate-400 font-normal text-xs">누적 조회 {product.views.toLocaleString()}회</span>
              </div>
            </div>

            <hr className="border-slate-100" />

            {/* Price Box */}
            <div className="flex items-center justify-between">
              <span className="text-sm font-semibold text-slate-500">판매 가격</span>
              <span className="font-sans font-bold text-xl sm:text-2xl text-slate-900">
                {product.price.toLocaleString()}원
              </span>
            </div>

            {/* Actions Card State based on Ownership */}
            <div className="pt-2">
              {purchased ? (
                // Purchased State
                <div id="purchased-actions-block" className="space-y-4">
                  <div className="flex items-center gap-2 rounded-xl bg-indigo-50/50 border border-indigo-100 px-4 py-3 text-indigo-800">
                    <ShieldCheck className="h-5 w-5 text-indigo-600 shrink-0" />
                    <span className="text-xs sm:text-sm font-semibold">이미 구매 완료한 상품입니다.</span>
                  </div>

                  <div className="rounded-xl border border-slate-200 bg-slate-900 p-4 shadow-inner text-white font-mono text-xs relative">
                    <div className="flex items-center justify-between mb-2 pb-2 border-b border-slate-800">
                      <span className="text-[10px] uppercase text-indigo-300 font-bold tracking-wider">Unlocks Prompt Code</span>
                      <button
                        id="copy-prompt-btn"
                        onClick={handleCopy}
                        className="flex items-center gap-1 bg-slate-800 hover:bg-slate-700 text-slate-200 rounded-lg px-2.5 py-1 text-[11px] font-semibold transition-all cursor-pointer"
                      >
                        {copied ? (
                          <>
                            <Check className="h-3 w-3 text-emerald-400" />
                            <span>복사됨</span>
                          </>
                        ) : (
                          <>
                            <Copy className="h-3 w-3 text-slate-400" />
                            <span>복사</span>
                          </>
                        )}
                      </button>
                    </div>
                    <p className="whitespace-pre-wrap select-all max-h-48 overflow-y-auto leading-relaxed text-slate-200 text-[11px]">
                      {product.prompt_text}
                    </p>
                  </div>
                  <p className="text-[11px] text-slate-400 text-center leading-normal">
                    * 위 터미널 박스에서 프롬프트를 확인하고 즉시 복사하여<br />
                    AI 서비스({product.category}) 환경에 붙여넣어 활용하세요!
                  </p>
                </div>
              ) : (
                // Unpurchased State
                <div id="unpurchased-actions-block" className="space-y-4">
                  {/* Blurred locked view */}
                  <div className="rounded-xl border border-slate-100 bg-slate-50 p-4 text-center">
                    <p className="text-xs font-semibold text-slate-500 leading-normal">
                      🔒 구매 시 프롬프트 전문을 확인하실 수 있습니다.
                    </p>
                  </div>

                  <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <button
                      id="details-add-to-cart-btn"
                      onClick={() => addToCart(product.id)}
                      disabled={inCart}
                      className={`flex w-full items-center justify-center gap-2 rounded-xl py-3 text-sm font-semibold transition-all border cursor-pointer ${
                        inCart
                          ? "bg-slate-100 text-slate-400 border-slate-100 cursor-not-allowed"
                          : "bg-white text-slate-700 border-slate-200 hover:bg-slate-50 hover:border-slate-300 active:scale-[0.98]"
                      }`}
                    >
                      <ShoppingCart className="h-4 w-4" />
                      <span>{inCart ? "장바구니에 있음" : "장바구니 담기"}</span>
                    </button>

                    <button
                      id="details-buy-now-btn"
                      onClick={handleDirectBuy}
                      className="flex w-full items-center justify-center gap-2 rounded-xl bg-slate-900 py-3 text-sm font-semibold text-white shadow-lg shadow-slate-900/10 hover:bg-slate-800 active:scale-[0.98] transition-all cursor-pointer"
                    >
                      <CreditCard className="h-4 w-4 text-slate-400" />
                      <span>바로 구매하기</span>
                    </button>
                  </div>
                </div>
              )}
            </div>

            {/* Satisfaction / Guarantee labels */}
            <div className="rounded-xl bg-slate-50 p-3.5 flex items-start gap-3">
              <Clock className="h-4 w-4 text-slate-400 shrink-0 mt-0.5" />
              <div className="text-[11px] leading-normal text-slate-500">
                <p className="font-semibold text-slate-700">디지털 다운로드 즉시 사용</p>
                <p className="mt-0.5">결제 성공 즉시 이 페이지 혹은 마이페이지 구매내역에서 프롬프트 원문 코드가 잠금해제됩니다.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Direct Buy Checkout Confirmation Modal */}
      {showCheckoutModal && (
        <div id="checkout-modal-overlay" className="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4 backdrop-blur-sm animate-in fade-in duration-200">
          <div className="w-full max-w-md overflow-hidden rounded-3xl bg-white p-6 shadow-2xl animate-in zoom-in-95 duration-200">
            <div className="flex items-center gap-2.5 text-indigo-600 mb-4">
              <div className="flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-50">
                <Sparkles className="h-5 w-5" />
              </div>
              <h3 className="font-display font-bold text-lg text-slate-900">결제 진행</h3>
            </div>

            <p className="text-sm text-slate-500 leading-relaxed mb-6">
              아래 상품을 단건으로 결제하고 프롬프트 잠금을 해제합니다.
            </p>

            <div className="rounded-2xl border border-slate-100 bg-slate-50/50 p-4 mb-6">
              <div className="flex gap-3">
                <div className="relative h-12 w-16 overflow-hidden rounded-lg bg-slate-100 shrink-0">
                  <Image
                    src={product.images[0]}
                    alt={product.title}
                    fill
                    sizes="64px"
                    className="object-cover"
                    referrerPolicy="no-referrer"
                  />
                </div>
                <div className="min-w-0 flex-1">
                  <p className="text-xs text-slate-400 font-semibold">{product.category}</p>
                  <p className="text-xs sm:text-sm font-bold text-slate-800 truncate leading-snug">{product.title}</p>
                  <p className="text-xs sm:text-sm font-bold text-indigo-600 mt-0.5">{product.price.toLocaleString()}원</p>
                </div>
              </div>
            </div>

            <div className="flex justify-between items-center bg-slate-900 text-white rounded-2xl p-4 mb-6">
              <span className="text-xs text-slate-400">최종 결제 금액</span>
              <span className="text-base sm:text-lg font-bold font-mono">{product.price.toLocaleString()}원</span>
            </div>

            <div className="grid grid-cols-2 gap-3">
              <button
                id="modal-cancel-btn"
                onClick={() => setShowCheckoutModal(false)}
                className="rounded-xl border border-slate-200 px-4 py-2.5 text-xs sm:text-sm font-semibold text-slate-600 bg-white hover:bg-slate-50 transition-all cursor-pointer"
              >
                취소
              </button>
              <button
                id="modal-confirm-btn"
                onClick={confirmDirectCheckout}
                className="rounded-xl bg-indigo-600 px-4 py-2.5 text-xs sm:text-sm font-semibold text-white hover:bg-indigo-700 shadow-sm shadow-indigo-600/10 transition-all cursor-pointer"
              >
                결제 승인
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
</file>

