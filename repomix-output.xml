                  </button>
                  <button
                    id="toss-method-tosspay"
                    onClick={() => setSelectedMethod("tosspay")}
                    className={`flex flex-col items-center justify-center p-3.5 rounded-2xl border-2 transition-all cursor-pointer ${
                      selectedMethod === "tosspay"
                        ? "border-blue-600 bg-blue-50/20 text-blue-700 font-semibold"
                        : "border-slate-100 hover:border-slate-200 text-slate-600"
                    }`}
                  >
                    <span className="text-xs flex items-center gap-1">
                      <span className="text-blue-600 font-extrabold font-sans text-xs">toss</span>페이
                    </span>
                  </button>
                  <button
                    id="toss-method-bank"
                    onClick={() => setSelectedMethod("bank")}
                    className={`col-span-2 flex items-center justify-between px-4 py-3 rounded-xl border-2 transition-all cursor-pointer ${
                      selectedMethod === "bank"
                        ? "border-blue-600 bg-blue-50/20 text-blue-700 font-semibold"
                        : "border-slate-100 hover:border-slate-200 text-slate-600"
                    }`}
                  >
                    <span className="text-xs">실시간 계좌이체</span>
                    <span className="text-[10px] text-slate-400">수수료 없음</span>
                  </button>
                </div>
              </div>

              {/* Consent checkmarks */}
              <div className="rounded-2xl bg-slate-50 p-4 border border-slate-100 space-y-2">
                <div className="flex items-center gap-2">
                  <input id="terms-1" type="checkbox" defaultChecked className="rounded border-slate-300 text-blue-600 focus:ring-blue-500" />
                  <label htmlFor="terms-1" className="text-xs text-slate-600 font-medium">개인정보 제공 동의 (필수)</label>
                </div>
                <div className="flex items-center gap-2">
                  <input id="terms-2" type="checkbox" defaultChecked className="rounded border-slate-300 text-blue-600 focus:ring-blue-500" />
                  <label htmlFor="terms-2" className="text-xs text-slate-600 font-medium">전자결제대행 이용약관 동의 (필수)</label>
                </div>
              </div>
            </div>

            {/* Pay Button */}
            <div className="p-6 border-t border-slate-100 bg-slate-50/50">
              <button
                id="toss-pay-submit-btn"
                onClick={handleTossPaySuccess}
                disabled={paymentLoading}
                className="w-full bg-[#1b64da] hover:bg-[#1551b8] disabled:bg-[#1b64da]/60 text-white py-3.5 rounded-2xl text-sm font-semibold shadow-lg shadow-blue-700/10 transition-all cursor-pointer flex items-center justify-center gap-2"
