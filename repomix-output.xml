"use client";

import React, { useState } from "react";
import Link from "next/link";
import { useRouter } from "next/navigation";
import { useApp } from "@/context/AppContext";
import { PROMPT_PRODUCTS } from "@/lib/promptData";
import { Trash2, ShoppingBag, ArrowRight, ShieldCheck, Sparkles, X, Check } from "lucide-react";
import Image from "next/image";

export default function CartPage() {
  const { cart, removeFromCart, addPurchases, addToast, user } = useApp();
  const router = useRouter();
  const [showTossWidget, setShowTossWidget] = useState(false);
  const [selectedMethod, setSelectedMethod] = useState("card");
  const [paymentLoading, setPaymentLoading] = useState(false);
  const [showSuccessModal, setShowSuccessModal] = useState(false);
  const [exitingIds, setExitingIds] = useState<Set<string>>(new Set());

  const handleRemoveFromCart = (id: string) => {
    setExitingIds((prev) => new Set([...prev, id]));
    setTimeout(() => {
      removeFromCart(id);
      setExitingIds((prev) => {
        const next = new Set(prev);
        next.delete(id);
        return next;
      });
    }, 200);
  };

  // Map product IDs in cart to detailed objects
  const cartItems = cart
    .map((id) => PROMPT_PRODUCTS.find((p) => p.id === id))
    .filter((p): p is typeof PROMPT_PRODUCTS[0] => !!p);

  const totalPrice = cartItems.reduce((sum, item) => sum + item.price, 0);

  const handleCheckoutClick = () => {
    if (!user) {
      addToast("결제하려면 로그인이 필요합니다.");
      router.push("/login");
      return;
    }
    setShowTossWidget(true);
  };

  const handleTossPaySuccess = () => {
    setPaymentLoading(true);
    // Simulate API gateway delay
    setTimeout(() => {
      setPaymentLoading(false);
      setShowTossWidget(false);

      // Perform transaction actions
      const productIdsToPurchase = cartItems.map((item) => item.id);
      addPurchases(productIdsToPurchase);

      // Open Success Modal
      setShowSuccessModal(true);
    }, 1500);
  };

  const handleSuccessClose = () => {
    setShowSuccessModal(false);
    router.push("/my-page");
  };

  return (
    <div id="cart-page-container" className="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <h1 className="font-display font-bold text-2xl sm:text-3xl text-slate-900 mb-8 border-b border-slate-100 pb-4 dark:text-zinc-50 dark:border-zinc-800">
        장바구니
