import type { Metadata } from "next";
import { PROMPT_PRODUCTS } from "@/lib/promptData";

interface Props {
  params: Promise<{ id: string }>;
}

export async function generateMetadata({ params }: Props): Promise<Metadata> {
  const { id } = await params;
  const product = PROMPT_PRODUCTS.find((p) => p.id === id);

  if (!product) {
    return {
      title: "프롬프트를 찾을 수 없음",
      description: "요청하신 프롬프트가 존재하지 않습니다.",
      openGraph: {
        title: "프롬프트를 찾을 수 없음 | Prompt Market",
        description: "요청하신 프롬프트가 존재하지 않습니다.",
        images: [{ url: "/og-image.png", width: 1200, height: 630, alt: "Prompt Market" }],
        type: "website",
      },
    };
  }

  const description = `${product.category} 카테고리 · ₩${product.price.toLocaleString()} · ${product.description.slice(0, 100).replace(/\n/g, " ")}…`;
  const ogImage = product.images[0] ?? "/og-image.png";

  return {
    title: product.title,
    description,
    openGraph: {
      title: `${product.title} | Prompt Market`,
      description,
      images: [
        {
          url: ogImage,
          width: 1200,
          height: 630,
          alt: product.title,
        },
      ],
      type: "website",
    },
    twitter: {
      card: "summary_large_image",
      title: `${product.title} | Prompt Market`,
      description,
      images: [ogImage],
    },
  };
}

